{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Region Catalog Entry",
  "description": "区域知识包结构",
  "type": "object",
  "required": ["id", "name", "match", "mode"],
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符（kebab-case）",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "description": "区域名称"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "别名或多语言名称"
    },
    "match": {
      "type": "object",
      "description": "空间匹配范围",
      "required": ["lon", "lat"],
      "properties": {
        "lon": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "经度范围 [min, max]"
        },
        "lat": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "纬度范围 [min, max]"
        }
      }
    },
    "geometry": {
      "type": "object",
      "description": "精确边界（GeoJSON 格式，可选）"
    },
    "type": {
      "type": "string",
      "enum": ["basin", "aquifer", "region", "country", "city", "ecoregion"],
      "description": "区域类型"
    },
    "parent": {
      "type": "string",
      "description": "父区域 ID"
    },
    "mode": {
      "type": "string",
      "enum": ["snow", "monsoon", "dryIrrigation", "reservoir", "humid", "managed", "mixed"],
      "description": "水文循环模式"
    },
    "label": {
      "type": "string",
      "description": "模式标签（中文描述）"
    },
    "summary": {
      "type": "string",
      "description": "研究摘要"
    },
    "cycle": {
      "type": "array",
      "items": { "type": "string" },
      "description": "水文循环特征"
    },
    "pattern": {
      "type": "array",
      "items": { "type": "string" },
      "description": "空间格局特征"
    },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "关联文献 ID"
    },
    "datasets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "关联数据集 ID"
    },
    "models": {
      "type": "array",
      "items": { "type": "string" },
      "description": "适用模型 ID"
    }
  }
}
